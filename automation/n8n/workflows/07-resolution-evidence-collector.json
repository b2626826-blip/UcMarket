    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const pages = $input.all().map((item) => item.json);\n\nconst authFailure = pages.find((page) => page.statusCode === 401 || page.statusCode === 403);\nif (authFailure) {\n  throw new Error(`07-resolution-evidence-collector candidate authentication rejected (HTTP ${authFailure.statusCode})`);\n}\n\nconst unavailable = pages.length === 0 || pages.some((page) =>\n  page.error || page.statusCode == null || page.statusCode >= 500\n);\nif (unavailable) {\n  throw new Error('07-resolution-evidence-collector candidate API unavailable');\n}\n\nconst unexpected = pages.find((page) => page.statusCode !== 200);\nif (unexpected) {\n  throw new Error(`07-resolution-evidence-collector unexpected candidate status (HTTP ${unexpected.statusCode})`);\n}\n\nconst orderedPages = [...pages].sort((a, b) => a.body.page - b.body.page);\nfor (let index = 0; index < orderedPages.length; index++) {\n  const body = orderedPages[index].body;\n  if (!body || !Array.isArray(body.content) || body.page !== index) {\n    throw new Error(`07-resolution-evidence-collector invalid pagination response at page ${index}`);\n  }\n  if (index < orderedPages.length - 1 && body.hasNext !== true) {\n    throw new Error(`07-resolution-evidence-collector pagination ended before page ${index + 1}`);\n  }\n}\n\nconst candidates = orderedPages\n  .flatMap((page) => page.body.content)\n  .slice(0, 200);\n\nreturn candidates.map((candidate, index) => {\n  const sourceUrl = typeof candidate?.sourceUrl === 'string' ? candidate.sourceUrl.trim() : '';\n  const hostnameMatch = /^https?:\\/\\/(?:[^@/?#]+@)?(\\[[^\\]]+\\]|[^:/?#]+)(?::\\d+)?(?:[/?#]|$)/i.exec(sourceUrl);\n  const sourceTitle = hostnameMatch\n    ? hostnameMatch[1].replace(/^\\[|\\]$/g, '').toLowerCase()\n    : 'invalid-source-url';\n\n  return {\n    json: {\n      marketId: typeof candidate?.marketId === 'string' ? candidate.marketId : '',\n      sourceUrl,\n      sourceTitle,\n      candidateIndex: index,\n    },\n  };\n});"
      },
