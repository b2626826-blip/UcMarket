    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const candidate = $('Prepare Retry').item.json;\nconst statusCode = Number($json.statusCode ?? $json.error?.statusCode ?? $json.error?.httpCode ?? $json.error?.status);\n\nif (statusCode === 401 || statusCode === 403) {\n  throw new Error(`07-resolution-evidence-collector write authentication rejected (HTTP ${statusCode})`);\n}\n\nconst success = Number.isInteger(statusCode) && statusCode >= 200 && statusCode < 300;\nconst transient = !success && (\n  $json.error != null || !Number.isInteger(statusCode) || statusCode === 429 || statusCode >= 500\n);\nconst shouldRetry = transient && candidate.retryAttempt < 2;\n\nreturn {\n  json: {\n    ...candidate,\n    outcome: success ? 'success' : (shouldRetry ? 'retry' : 'failed'),\n    shouldRetry,\n    statusCode: Number.isInteger(statusCode) ? statusCode : null,\n  },\n};"
      },
