{
	admin off
	email {$ACME_EMAIL}
}

(demo_auth) {
	basic_auth {
		{$DEMO_AUTH_USERNAME} {$DEMO_AUTH_PASSWORD_HASH}
	}
}

ucmarket.online, www.ucmarket.online {
	import demo_auth
	encode zstd gzip

	@api path /api/*
	handle @api {
		reverse_proxy backend:8080
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

n8n.ucmarket.online {
	@notify path /webhook/notify
	handle @notify {
		reverse_proxy n8n:5678
	}

	import demo_auth
	reverse_proxy n8n:5678
}
