{
	admin off
	email {$ACME_EMAIL}
}

ucmarket.online, www.ucmarket.online {
	encode zstd gzip

	@api path /api/*
	handle @api {
		reverse_proxy backend:8080
	}

	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

n8n.ucmarket.online {
	@notify path /webhook/notify
	handle @notify {
		reverse_proxy n8n:5678
	}

	reverse_proxy n8n:5678
}
